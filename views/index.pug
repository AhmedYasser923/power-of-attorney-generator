extends layout

block content
  //- Note: Add link(rel="stylesheet", href="/css/poa-form.css") to your layout.pug <head> 

  #loader-overlay.poa-loader
    .modern-spinner
    p.poa-loader__text Generating PDF... Please wait

  .poa-container
    h2.poa-title Generate Power of Attorney
    
    //- AI ANALYZER REDIRECTION BANNER
    a.poa-banner(href="/ticket-analyzer")
      .poa-banner__content
        h3.poa-banner__title ✨ Ticket Analyzer
        p.poa-banner__desc Instantly extract passenger data, routes, and EC261/UK261 eligibility from any screenshot.
      .poa-banner__btn Launch Analyzer ➔
    
    if error
      .poa-error= error
    
    .poa-form-group
      label.poa-label(for="templateSelector") Select Template Format *
      select#templateSelector.poa-select
        option(value="standard") Standard ReFly Template (1 Passenger)
        option(value="lufthansa") Lufthansa Template (Up to 4 Passengers)
        option(value="aerlingus") Aer Lingus Template (1 Passenger)

    hr.poa-divider

    //- AI AUTOFILL & UNIFIED PASTE SECTION
    .poa-ai-zone#aiZoneContainer
      label.poa-ai-zone__label ✨ AI Autofill & Signature Drop
      p.poa-ai-zone__desc Use <b>Ditto</b> to paste text and signatures globally. Text goes to AI, images auto-attach to the active form below.
      textarea#aiAutofillInput.poa-textarea(rows="3" placeholder="Paste text here...")
      button#aiAutofillBtn.poa-btn.poa-btn--success(type="button") Extract & Fill Form

    //- FORM 1: STANDARD REFLY TEMPLATE
    form#standardForm.poa-form(action="/generate-standard", method="POST", enctype="multipart/form-data", autocomplete="off")
      h3.poa-form-title Standard Form Details
      
      .poa-highlight-box
        label.poa-label Document Language:
        select.poa-select(name="lang")
          option(value="En" selected) English (En)
          option(value="Fr") French (Fr)
          option(value="De") German (De)
          option(value="Es") Spanish (Es)
          option(value="It") Italian (It)
          option(value="Pt") Portuguese (Pt)
          option(value="Tr") Turkish (Tr)
          option(value="Ar") Arabic (Ar)
          option(value="Pl") Polish (Pl)
          option(value="Sv") Swedish (Sv)
          option(value="No") Norwegian (No)
          option(value="Da") Danish (Da)
          option(value="Fi") Finnish (Fi)
          option(value="Nl") Dutch (Nl)
          option(value="Ro") Romanian (Ro)
          option(value="Hi") Hindi (Hi)
          option(value="Ja") Japanese (Ja)
          option(value="He") Hebrew (He)
          option(value="CH") chienese (Ch)
          option(value="Al") albanian (Al)

      .poa-form-group
        label.poa-label First Name *
        input.poa-input(type="text", name="firstName", required)
      .poa-form-group
        label.poa-label Last Name *
        input.poa-input(type="text", name="lastName", required)
      .poa-form-group
        label.poa-label Address *
        textarea.poa-textarea(name="address", rows="3", required)
      .poa-form-group
        label.poa-label PNR Number *
        input.poa-input(type="text", name="pnr", required, minlength="5", pattern="[A-Za-z0-9]{5,}")
      .poa-form-group
        label.poa-label Date *
        input.poa-input(type="date", name="date", required)
      
      .poa-form-group
        label.poa-label Signature Image (optional)
        .drop-zone.poa-dropzone
          p.drop-zone-text.poa-dropzone__text Click to Upload, Drag & Drop, or Paste (Ctrl+V)
          input.sig-file-input(type="file", name="signature", accept="image/*", style="display: none;")
          img.sig-preview(src="", style="max-height: 80px; display: none; margin: 10px auto;")
      
      .poa-sig-processing-box
        label.poa-label Signature Processing Option
        select.poa-select(name="sigProcessing")
          option(value="none") None (Use Raw Image)
          option(value="cloudinary") Cloudinary AI (Standard Background Removal)
          option(value="gemini", selected) Nano Banana (Deep Clean & Thicken)
      
      button.poa-btn.poa-btn--primary.poa-mt-20(type="submit") Generate Standard PDF

    //- FORM 2: LUFTHANSA TEMPLATE
    form#lufthansaForm.poa-form(action="/generate-lufthansa", method="POST", enctype="multipart/form-data", style="display: none;", autocomplete="off")
      h3.poa-form-title Lufthansa Form Details
      .poa-row
        .poa-col
          label.poa-label Flight Number
          input.poa-input(type="text", name="flightNumber")
        .poa-col
          label.poa-label PNR / Booking Code *
          input.poa-input(type="text", name="pnr", required, minlength="5", maxlength="9", pattern="[A-Za-z0-9]{5,9}")
        .poa-col
          label.poa-label Flight Date *
          input.poa-input(type="date", name="flightDate", required)

      .poa-row.poa-row--align-start.poa-mt-20
        .poa-col.poa-col--1-2
          h4 Passenger Details
          #names-container.poa-panel
            - for (var i = 1; i <= 4; i++)
              .poa-row.poa-row--no-margin.poa-row--center
                .poa-col.poa-col--no-margin
                  label.poa-label Passenger #{i} Full Name #{i === 1 ? '*' : '(Optional)'}
                  input.poa-input(type="text", name=`fullName${i}`, placeholder="e.g. Pamela Nelson", required=(i === 1))
              if i === 1
                .poa-row.poa-row--no-margin.poa-mt-10
                  .poa-col.poa-col--no-margin
                    label.poa-label Main Claimer Address *
                    textarea.poa-textarea(name="address1", rows="2", required=true)

        .poa-col.poa-col--1
          h4 Signatures
          #signatures-container.poa-panel
            .poa-form-group.poa-form-group--no-margin
              label.poa-label Claim Submission Date *
              input.poa-input(type="date", name="claimDate", required)
            
            .drop-zone.poa-dropzone#lufthansa-drop-zone
              p.drop-zone-text.poa-dropzone__text Click to Upload, Drag & Drop, or Paste (Ctrl+V)
              input#lufthansa-sig-input(type="file", name="signatures", accept="image/*", multiple=true, style="display: none;")
            
            #lufthansa-sig-previews.poa-sig-previews
              span#preview-placeholder.poa-preview-placeholder Previews appear here...
            
            div
              label.poa-label.poa-label--bold Processing Method per Signature:
              .poa-sig-processing-list
                - for (var i = 1; i <= 4; i++)
                  .poa-sig-processing-item
                    label.poa-sig-processing-item__label Sig #{i}:
                    select.poa-select.poa-select--small(name=`sigProcessing${i}`)
                      option(value="none") None (Raw)
                      option(value="cloudinary") Cloudinary AI
                      option(value="gemini", selected) Nano Banana

      button.poa-btn.poa-btn--primary.poa-btn--full.poa-mt-25(type="submit") Generate Lufthansa PDF

    //- FORM 3: AER LINGUS TEMPLATE
    form#aerLingusForm.poa-form(action="/generate-aerlingus", method="POST", enctype="multipart/form-data", style="display: none;", autocomplete="off")
      h3.poa-form-title Aer Lingus Form Details
      
      .poa-highlight-box--teal
        .poa-row
          .poa-col
            label.poa-label Type of Claim *
            select.poa-select(name="claimType" required)
              option(value="compensation") Compensation Claim (Regulation EC 261/2004)
              option(value="expense") Expense Claim
              option(value="baggage") Delayed, Lost or Damaged Baggage Claim
              option(value="complaint") Complaint
              option(value="other") Other
          .poa-col
            label.poa-label Case Number (Optional)
            input.poa-input(type="text", name="caseNumber")

      .poa-row
        .poa-col
          label.poa-label Passenger First Name *
          input.poa-input(type="text", name="firstName", required)
        .poa-col
          label.poa-label Passenger Last Name *
          input.poa-input(type="text", name="lastName", required)
      
      .poa-form-group
        label.poa-label Passenger Address *
        textarea.poa-textarea(name="address", rows="2", required)
      
      .poa-row
        .poa-col
          label.poa-label PNR / Booking Code *
          input.poa-input(type="text", name="pnr", required, minlength="5", maxlength="9", pattern="[A-Za-z0-9]{5,9}")
        .poa-col
          label.poa-label Flight Number
          input.poa-input(type="text", name="flightNumber")
        .poa-col
          label.poa-label Flight Date *
          input.poa-input(type="date", name="flightDate", required)
      
      .poa-form-group
        label.poa-label Route (Specify to and from)
        input.poa-input(type="text", name="route", placeholder="e.g. DUB - JFK")

      .poa-form-group
        label.poa-label Signature Image *
        .drop-zone.poa-dropzone
          p.drop-zone-text.poa-dropzone__text Click to Upload, Drag & Drop, or Paste (Ctrl+V)
          input.sig-file-input(type="file", name="signature", accept="image/*", style="display: none;", required)
          img.sig-preview(src="", style="max-height: 80px; display: none; margin: 10px auto;")
      
      .poa-sig-processing-box
        label.poa-label Signature Processing Option
        select.poa-select(name="sigProcessing")
          option(value="none") None (Use Raw Image)
          option(value="cloudinary") Cloudinary AI (Standard Background Removal)
          option(value="gemini", selected) Nano Banana (Deep Clean & Thicken)

      button.poa-btn.poa-btn--aerlingus.poa-btn--full.poa-mt-25(type="submit") Generate Aer Lingus PDF

  //- Include the extracted logic
  script(src="/js/poa-form.js")