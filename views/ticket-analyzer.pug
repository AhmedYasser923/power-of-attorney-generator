extends layout

block content
  style.
    /* --- MODERN UI/UX COLOR PALETTE & TYPOGRAPHY --- */
    :root {
      --bg-body: #f4f7fb;
      --surface: #ffffff;
      --primary: #2563eb;
      --primary-hover: #1d4ed8;
      --secondary: #475569;
      --text-main: #0f172a;
      --text-muted: #64748b;
      --border-soft: #e2e8f0;
      --accent-blue: #eff6ff;
      --radius-lg: 16px;
      --radius-md: 12px;
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.05);
      --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.03);
      --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.05), 0 4px 6px -2px rgba(0,0,0,0.025);
    }

    body { background-color: var(--bg-body); }

    .header-title { font-size: 32px; font-weight: 800; color: var(--text-main); margin-bottom: 8px; letter-spacing: -0.5px; }
    .header-subtitle { font-size: 15px; color: var(--text-muted); margin-bottom: 32px; line-height: 1.5; }

    /* --- DROP ZONE --- */
    .drop-zone { border: 2px dashed #cbd5e1; background-color: var(--surface); border-radius: var(--radius-lg); padding: 60px 20px; text-align: center; cursor: pointer; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: var(--shadow-sm); outline: none; }
    .drop-zone:hover, .drop-zone:focus, .drop-zone.dragover { border-color: var(--primary); background-color: var(--accent-blue); transform: translateY(-2px); box-shadow: var(--shadow-md); }
    .dz-icon { font-size: 48px; margin-bottom: 16px; transition: transform 0.3s; display: inline-block; }
    .drop-zone:hover .dz-icon { transform: scale(1.1) translateY(-5px); }
    .dz-title { font-size: 18px; font-weight: 700; color: var(--text-main); margin: 0 0 8px 0; }
    .dz-text { font-size: 13px; color: var(--text-muted); margin: 0; }

    /* --- BUTTONS --- */
    .btn-analyze { background: var(--primary); color: white; border: none; border-radius: var(--radius-md); padding: 14px 24px; font-size: 16px; font-weight: 600; width: 100%; cursor: pointer; transition: all 0.2s ease; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2); }
    .btn-analyze:hover { background: var(--primary-hover); transform: translateY(-1px); box-shadow: 0 6px 16px rgba(37, 99, 235, 0.3); }
    .btn-analyze:disabled { background: #94a3b8; cursor: not-allowed; transform: none; box-shadow: none; animation: pulse 2s infinite; }
    @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.7; } 100% { opacity: 1; } }

    /* --- RESULTS CONTAINERS --- */
    .results-container { background: var(--surface); border: 1px solid var(--border-soft); border-radius: var(--radius-lg); padding: 32px; box-shadow: var(--shadow-lg); margin-top: 32px; animation: fadeIn 0.5s ease; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    /* Flight Card & Data Styling */
    .ec261-card { display: flex; align-items: center; gap: 16px; padding: 16px 20px; border-radius: var(--radius-md); margin-bottom: 20px; }
    .ec261-card.eligible { background-color: #f0fdf4; border: 1px solid #bbf7d0; }
    .ec261-card.eligible .ec-icon { color: #16a34a; }
    .ec261-card.eligible .ec-title { color: #15803d; }
    .ec261-card.not-eligible { background-color: #fef2f2; border: 1px solid #fecaca; }
    .ec261-card.not-eligible .ec-icon { color: #dc2626; }
    .ec261-card.not-eligible .ec-title { color: #b91c1c; }
    .ec-icon { font-size: 32px; }
    .ec-content { flex: 1; }
    .ec-title { font-size: 16px; font-weight: 800; margin: 0 0 4px 0; text-transform: uppercase; letter-spacing: 0.5px; }
    .ec-reason { font-size: 13px; color: var(--text-muted); margin: 0; line-height: 1.4; }
    
    .passenger-card { background: linear-gradient(145deg, #ffffff, #f8fafc); border: 1px solid var(--border-soft); border-radius: var(--radius-md); padding: 20px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .p-label { font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
    .p-value { font-size: 20px; font-weight: 800; color: var(--text-main); }
    .pnr-box { background: var(--accent-blue); padding: 10px 16px; border-radius: 8px; text-align: right; border: 1px solid #bfdbfe; }
    .pnr-box .p-value { color: var(--primary); font-family: monospace; font-size: 22px; letter-spacing: 2px; }
    
    .route-header { font-size: 16px; font-weight: 800; color: var(--text-main); margin: 32px 0 16px 0; display: flex; align-items: center; gap: 10px; }
    .route-header::before { content: ''; display: block; width: 8px; height: 24px; background: var(--primary); border-radius: 4px; }
    
    .flight-card { background: var(--surface); border: 1px solid var(--border-soft); border-radius: var(--radius-md); padding: 24px; margin-bottom: 16px; transition: all 0.2s ease; }
    .flight-card:hover { border-color: #cbd5e1; box-shadow: var(--shadow-md); }
    .fc-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .fc-badge { background: #f1f5f9; color: var(--text-muted); font-size: 12px; font-weight: 700; padding: 4px 10px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.5px; }
    .fc-airline { display: flex; align-items: center; gap: 8px; font-weight: 600; color: var(--text-main); font-size: 14px; }
    .fc-path-container { display: flex; justify-content: space-between; align-items: flex-start; position: relative; }
    .fc-node { flex: 1; z-index: 2; }
    .fc-node.right { text-align: right; }
    .fc-iata { font-size: 32px; font-weight: 800; color: var(--text-main); letter-spacing: -1px; line-height: 1; }
    .fc-airport { font-size: 13px; color: var(--text-main); font-weight: 600; margin-top: 8px; margin-bottom: 2px; line-height: 1.3; }
    .fc-city { font-size: 12px; color: var(--text-muted); font-weight: 500; }
    .fc-time { font-size: 18px; font-weight: 700; color: var(--primary); margin-top: 10px; }
    .fc-line-wrapper { flex: 1.5; position: relative; display: flex; align-items: center; justify-content: center; padding: 0 20px; margin-top: 15px; }
    .fc-line { width: 100%; border-top: 2px dashed #cbd5e1; position: absolute; }
    .fc-plane { background: var(--surface); color: var(--text-muted); padding: 0 12px; z-index: 2; font-size: 20px; transform: rotate(90deg); }
    .fc-bottom { margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--border-soft); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; font-size: 13px; font-weight: 500; color: var(--text-muted); }
    .fc-flight-num { background: var(--accent-blue); color: var(--primary); padding: 4px 10px; border-radius: 6px; font-weight: 700; }
    .fc-ec-badge { font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: 6px; text-transform: uppercase; letter-spacing: 0.5px; cursor: help; display: flex; align-items: center; gap: 5px; }
    .fc-ec-badge.eligible { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
    .fc-ec-badge.not-eligible { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }

  .container(style="max-width: 850px; margin-top: 50px;")
    .header-title 🎫 Ticket Analyzer AI
    .header-subtitle Drop multiple e-tickets, boarding passes, or flight screenshots below. Our vision model will instantly extract structured passenger data and evaluate EC261 / UK261 claim eligibility.
    
    //- Interactive Drop Zone
    .drop-zone#ticketDropZone(tabindex="0")
      .dz-icon 📥
      .dz-title Click, Drag & Drop, or Paste (Ctrl+V)
      .dz-text Supports multiple PDFs, PNGs, and JPGs at once
      input#ticketInput(type="file", accept="image/*,application/pdf", multiple, style="display: none;")
    
    //- Action Area
    #previewTicketContainer(style="display: none; margin-top: 24px; text-align: center;")
      div(style="display: flex; justify-content: center; align-items: center; gap: 12px; margin-bottom: 16px;")
        p#ticketNameDisplay(style="font-weight: 600; color: var(--primary); margin: 0; font-size: 14px; background: var(--accent-blue); padding: 8px 18px; border-radius: 20px;")
        button#clearFilesBtn(type="button" title="Clear all files" style="background: #fee2e2; color: #ef4444; border: none; border-radius: 50%; width: 32px; height: 32px; cursor: pointer; font-size: 14px; display: flex; align-items: center; justify-content: center; transition: 0.2s;") ✖
      
      button#analyzeBtn.btn-analyze ✨ Extract Ticket Data

    //- Results Dashboard
    #resultsCard.results-container(style="display: none;")

  script.
    document.addEventListener('DOMContentLoaded', () => {
      const ticketDropZone = document.getElementById('ticketDropZone');
      const ticketInput = document.getElementById('ticketInput');
      const previewTicket = document.getElementById('previewTicketContainer');
      const ticketName = document.getElementById('ticketNameDisplay');
      const analyzeBtn = document.getElementById('analyzeBtn');
      const clearBtn = document.getElementById('clearFilesBtn');
      const resultsCard = document.getElementById('resultsCard');
      
      let currentFiles = [];

      function updateUI() {
        if (currentFiles.length === 0) {
          previewTicket.style.display = 'none';
          resultsCard.style.display = 'none';
          return;
        }
        ticketName.innerText = currentFiles.length === 1 ? `📄 1 File Ready: ${currentFiles[0].name}` : `📄 ${currentFiles.length} Files Ready`;
        previewTicket.style.display = 'block';
      }

      function handleFiles(fileList) {
        if (!fileList || fileList.length === 0) return;
        currentFiles = [...currentFiles, ...Array.from(fileList)];
        updateUI();
      }

      // Drag, Drop & Click Logic
      clearBtn.addEventListener('click', () => { currentFiles = []; ticketInput.value = ""; updateUI(); });
      ticketDropZone.addEventListener('click', () => { ticketInput.click(); });
      ticketInput.addEventListener('change', (e) => handleFiles(e.target.files));
      ticketDropZone.addEventListener('dragover', (e) => { e.preventDefault(); ticketDropZone.classList.add('dragover'); });
      ticketDropZone.addEventListener('dragleave', (e) => { e.preventDefault(); ticketDropZone.classList.remove('dragover'); });
      ticketDropZone.addEventListener('drop', (e) => {
        e.preventDefault();
        ticketDropZone.classList.remove('dragover');
        if (e.dataTransfer.files.length) handleFiles(e.dataTransfer.files);
      });

      // SMART PASTING LOGIC (Ctrl+V)
      document.addEventListener('paste', (e) => {
        const clipboard = e.clipboardData || window.clipboardData;
        if (!clipboard.items) return;
        
        const pastedFiles = [];
        for (let item of clipboard.items) {
          if (item.type.startsWith('image/') || item.type === 'application/pdf') {
            const file = item.getAsFile();
            const ext = file.type.split('/')[1] || 'png';
            pastedFiles.push(new File([file], `Pasted_Document_${Date.now()}.${ext}`, { type: file.type }));
          }
        }
        
        if (pastedFiles.length > 0) {
          currentFiles = [...currentFiles, ...pastedFiles];
          updateUI();
        }
      });

      // --- AI EXTRACTION LOGIC ---
      analyzeBtn.addEventListener('click', async () => {
        if (currentFiles.length === 0) return;
        
        const originalText = analyzeBtn.innerText;
        analyzeBtn.innerText = '⏳ AI is analyzing...';
        analyzeBtn.disabled = true;

        const formData = new FormData();
        currentFiles.forEach(file => formData.append('ticket', file));

        try {
          const response = await fetch('/api/analyze-ticket', { method: 'POST', body: formData });
          if (!response.ok) throw new Error('Analysis failed');
          let dataArray = await response.json();
          
          if (!Array.isArray(dataArray)) dataArray = [dataArray];

          resultsCard.innerHTML = '';

          dataArray.forEach((data, journeyIndex) => {
            const journeyWrapper = document.createElement('div');
            journeyWrapper.style.marginBottom = "60px";
            journeyWrapper.style.borderBottom = journeyIndex < dataArray.length - 1 ? "3px dashed var(--border-soft)" : "none";
            journeyWrapper.style.paddingBottom = journeyIndex < dataArray.length - 1 ? "40px" : "0";

            // Add Header
            if (dataArray.length > 1) {
              journeyWrapper.innerHTML += `<h3 style="color: var(--primary); border-bottom: 1px solid var(--border-soft); padding-bottom: 10px;">🎫 Ticket / Journey ${journeyIndex + 1}</h3>`;
            }

            // Render Overall EC261 Claim
            if (data.ec261) {
              const isEligible = data.ec261.status && data.ec261.status.toLowerCase().includes('not') === false;
              const cardClass = isEligible ? 'eligible' : 'not-eligible';
              const icon = isEligible ? '🛡️' : '⚠️';
              journeyWrapper.innerHTML += `<div class="ec261-card ${cardClass}"><div class="ec-icon">${icon}</div><div class="ec-content"><h4 class="ec-title">OVERALL CLAIM: ${data.ec261.status.toUpperCase()}</h4><p class="ec-reason">${data.ec261.reason}</p></div></div>`;
            }
            
            // --- SMART PASSENGER/PNR DE-DUPLICATION ---
            let showPassengerCard = true;
            if (journeyIndex > 0) {
              const prevData = dataArray[journeyIndex - 1];
              if (data.pnr === prevData.pnr && data.passengerName === prevData.passengerName) {
                showPassengerCard = false;
              }
            }

            if (showPassengerCard) {
              // --- TICKET NUMBER & PNR NOTE UI ---
              let pnrNoteHtml = '';
              if (data.pnrNote) {
                pnrNoteHtml = `<div style="margin-top: 10px; font-size: 11px; color: #0284c7; background: #e0f2fe; padding: 6px 10px; border-radius: 6px; max-width: 240px; text-align: right; line-height: 1.3; font-weight: 600;">${data.pnrNote}</div>`;
              }

              journeyWrapper.innerHTML += `
                <div class="passenger-card">
                  <div style="flex: 1;">
                    <div class="p-label">Passenger Name</div>
                    <div class="p-value" style="margin-bottom: 12px;">${data.passengerName || 'Not Found'}</div>
                    
                    <div class="p-label">Ticket Number</div>
                    <div class="p-value" style="font-size: 16px; font-family: monospace; color: var(--secondary);">${data.ticketNumber || 'Not Provided'}</div>
                  </div>
                  <div class="pnr-box" style="display: flex; flex-direction: column; justify-content: center; align-items: flex-end;">
                    <div class="p-label">PNR / Booking Ref</div>
                    <div class="p-value">${data.pnr || 'Not Found'}</div>
                    ${pnrNoteHtml}
                  </div>
                </div>
              `;
            }
            // ------------------------------------------------
            
            const flightCardsContainer = document.createElement('div');
            
            if (data.routes && data.routes.length > 0) {
              data.routes.forEach((route) => {
                flightCardsContainer.innerHTML += `<div class="route-header">${route.type || 'Flight Route'}</div>`;
                
                if (route.legs && route.legs.length > 0) {
                  route.legs.forEach((flight, index) => {
                    const legIndicator = route.legs.length > 1 ? `Leg ${index + 1}` : 'Direct';
      
                    // Evaluate Individual Leg Badge
                    let legBadgeHtml = '';
                    if (flight.ec261Leg && flight.ec261Leg.status) {
                      const lEl = !flight.ec261Leg.status.toLowerCase().includes('not');
                      legBadgeHtml = `<div class="fc-ec-badge ${lEl ? 'eligible' : 'not-eligible'}" title="${flight.ec261Leg.reason}">${lEl ? '✅' : '❌'} ${flight.ec261Leg.status}</div>`;
                    }

                    // Format Airline Text
                    let airText = `✈️ Booked: ${flight.marketingAirline || 'Unknown'}`;
                    if (flight.operatingAirline && flight.operatingAirline !== flight.marketingAirline) {
                      airText += ` <span style="color:var(--primary); margin-left:8px;">| Operated: ${flight.operatingAirline}</span>`;
                    }
                    
                    // --- CANCELLATION/REBOOKING UI LOGIC ---
                    let statusWarningHtml = '';
                    let opacityStyle = '1';
                    if (flight.flightStatus && flight.flightStatus.toLowerCase().includes('cancel')) {
                      statusWarningHtml = `<div style="background: #fee2e2; color: #dc2626; padding: 6px 12px; border-radius: 6px; font-weight: 800; font-size: 12px; margin-bottom: 16px; display: inline-block; border: 1px solid #fecaca;">⚠️ FLIGHT CANCELLED / REBOOKED</div>`;
                      opacityStyle = '0.55'; // Visually dim the card
                    }

                    flightCardsContainer.innerHTML += `
                      <div class="flight-card" style="opacity: ${opacityStyle};">
                        ${statusWarningHtml}
                        <div class="fc-top"><div class="fc-airline">${airText}</div><div class="fc-badge">${legIndicator}</div></div>
                        <div class="fc-path-container">
                          <div class="fc-node left"><div class="fc-iata">${flight.originIata || '???'}</div><div class="fc-airport">${flight.originName || ''}</div><div class="fc-city">${flight.originCity || ''}, ${flight.originCountry || ''}</div><div class="fc-time">${flight.departureTime || '--:--'}</div></div>
                          <div class="fc-line-wrapper"><div class="fc-line"></div><div class="fc-plane">✈</div></div>
                          <div class="fc-node right"><div class="fc-iata">${flight.destinationIata || '???'}</div><div class="fc-airport">${flight.destinationName || ''}</div><div class="fc-city">${flight.destinationCity || ''}, ${flight.destinationCountry || ''}</div><div class="fc-time">${flight.arrivalTime || '--:--'}</div></div>
                        </div>
                        <div class="fc-bottom">
                          <div style="display: flex; align-items: center; gap: 15px;">
                            <div>📅 ${flight.date || 'Unknown'}</div>
                            <div class="fc-flight-num">Flight: ${flight.flightNumber || 'N/A'}</div>
                          </div>
                          ${legBadgeHtml}
                        </div>
                      </div>`;
                  });
                } else {
                   flightCardsContainer.innerHTML += '<p style="color: var(--text-muted); font-size: 14px;">No leg data found for this route.</p>';
                }
              });
            } else {
               flightCardsContainer.innerHTML = '<div style="text-align: center; padding: 40px; color: var(--text-muted); background: var(--surface); border-radius: var(--radius-md); border: 1px dashed var(--border-soft);">No flight routes detected.</div>';
            }

            journeyWrapper.appendChild(flightCardsContainer);
            resultsCard.appendChild(journeyWrapper);
          });

          resultsCard.style.display = 'block';
        } catch (error) {
          alert('Failed to extract data. Ensure the images are clear.');
          console.error(error);
        } finally {
          analyzeBtn.innerText = originalText;
          analyzeBtn.disabled = false;
        }
      });
    });