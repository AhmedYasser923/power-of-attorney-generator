extends layout

block content
  //- Note: You must add link(rel="stylesheet", href="/css/ticket-analyzer.css") to your layout.pug <head> 
  //- or simply paste the contents of ticket-analyzer.css into your main style.css

  .ta-layout
    h1.ta-header__title 🎫 Ticket Analyzer 
    p.ta-header__subtitle Drop multiple e-tickets, boarding passes, or flight screenshots below. Our vision model will instantly extract structured passenger data and evaluate EC261 / UK261 claim eligibility.
    
    //- Interactive Drop Zone (IDs preserved for ticket-analyzer.js functionality)
    .ta-dropzone#ticketDropZone(tabindex="0")
      span.ta-dropzone__icon 📥
      h2.ta-dropzone__title Click, Drag & Drop, or Paste (Ctrl+V)
      p.ta-dropzone__text Supports multiple PDFs, PNGs, and JPGs at once
      input.ta-dropzone__input#ticketInput(type="file", accept="image/*,application/pdf", multiple)
    
    //- Action Area
    .ta-preview#previewTicketContainer
      .ta-preview__header
        p.ta-preview__name#ticketNameDisplay
        button.ta-preview__clear-btn#clearFilesBtn(type="button" title="Clear all files") ✖
      
      button.ta-preview__analyze-btn#analyzeBtn ✨ Extract Ticket Data

    //- Results Dashboard
    .ta-results#resultsCard

  script(src="/js/ticket-analyzer.js")